<UserControl x:Class="RegulationAssistantChatClient.Views.DocumentsView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 xmlns:res="clr-namespace:RegulationAssistantChatClient.Properties"
 mc:Ignorable="d"
 Height="Auto" Width="Auto">
	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<!-- DataGrid with improved dark styling to make columns and content clearly visible -->
		<DataGrid x:Name="DocumentsDataGrid" Grid.Row="0"
	    ItemsSource="{Binding Documents}"
	    SelectedItem="{Binding SelectedDocument, Mode=TwoWay}"
	    AutoGenerateColumns="False"
	    CanUserAddRows="False"
	    CanUserDeleteRows="False"
	    HeadersVisibility="Column"
	    GridLinesVisibility="None"
	    RowHeaderWidth="0"
	    Background="{StaticResource BackgroundBrush}"
	    Foreground="{StaticResource ForegroundBrush}"
	    HorizontalGridLinesBrush="Transparent"
	    VerticalGridLinesBrush="Transparent"
	    SelectionMode="Single"
	    SelectionUnit="FullRow"
	    FontSize="14"
	    IsReadOnly="True">

			<DataGrid.Resources>
				<Style TargetType="DataGridColumnHeader">
					<Setter Property="Background" Value="{StaticResource BackgroundBrush}" />
					<Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
					<Setter Property="BorderBrush" Value="{StaticResource ForegroundBrush}" />
					<Setter Property="Padding" Value="6,4" />
					<Setter Property="FontWeight" Value="Bold" />
				</Style>

				<Style TargetType="DataGridCell">
					<Setter Property="Background" Value="{StaticResource TextBoxBackgroundBrush}" />
					<!-- set cell text to black for maximum contrast -->
					<Setter Property="Foreground" Value="Black" />
					<Setter Property="BorderBrush" Value="{StaticResource ForegroundBrush}" />
					<Setter Property="Padding" Value="6,4" />
					<Setter Property="FontSize" Value="14" />
				</Style>

				<!-- Ensure textblocks inside cells use black foreground for contrast -->
				<Style x:Key="DataGridCellTextStyle" TargetType="TextBlock">
					<Setter Property="Foreground" Value="Black" />
					<Setter Property="VerticalAlignment" Value="Center" />
					<Setter Property="FontSize" Value="14" />
				</Style>
			</DataGrid.Resources>

			<DataGrid.RowStyle>
				<Style TargetType="DataGridRow">
					<Setter Property="Background" Value="{StaticResource TextBoxBackgroundBrush}" />
					<Setter Property="Foreground" Value="Black" />
					<Setter Property="Margin" Value="0,0,0,2" />
					<Style.Triggers>
						<Trigger Property="IsSelected" Value="True">
							<Setter Property="Background" Value="{StaticResource ForegroundBrush}" />
							<!-- keep selected row text black for readability -->
							<Setter Property="Foreground" Value="Black" />
						</Trigger>
					</Style.Triggers>
				</Style>
			</DataGrid.RowStyle>

			<DataGrid.Columns>
				<DataGridTextColumn Header="{x:Static res:Resources.Documents_TitleHeader}" Binding="{Binding Title}" Width="*">
					<DataGridTextColumn.ElementStyle>
						<Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}" />
					</DataGridTextColumn.ElementStyle>
				</DataGridTextColumn>

				<DataGridTextColumn Header="{x:Static res:Resources.Documents_VersionHeader}" Binding="{Binding VersionNumber}" Width="100">
					<DataGridTextColumn.ElementStyle>
						<Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}">
							<Setter Property="TextBlock.TextAlignment" Value="Center" />
						</Style>
					</DataGridTextColumn.ElementStyle>
				</DataGridTextColumn>

				<DataGridTextColumn Header="{x:Static res:Resources.Documents_ValidFromHeader}" Binding="{Binding ValidFrom, StringFormat=d}" Width="140" IsReadOnly="True">
					<DataGridTextColumn.ElementStyle>
						<Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}">
							<Setter Property="TextBlock.TextAlignment" Value="Center" />
						</Style>
					</DataGridTextColumn.ElementStyle>
				</DataGridTextColumn>

				<DataGridTextColumn Header="{x:Static res:Resources.Documents_ValidToHeader}" Binding="{Binding ValidTo, StringFormat=d}" Width="140" IsReadOnly="True">
					<DataGridTextColumn.ElementStyle>
						<Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}">
							<Setter Property="TextBlock.TextAlignment" Value="Center" />
						</Style>
					</DataGridTextColumn.ElementStyle>
				</DataGridTextColumn>
			</DataGrid.Columns>
		</DataGrid>

		<StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
			<Button Command="{Binding NewCommand}" Width="60" Height="30" Margin="0,0,10,0" Content="{x:Static res:Resources.NewButton}" />
			<Button Command="{Binding UploadCommand}" Width="80" Height="30" Margin="0,0,10,0" Content="{x:Static res:Resources.UploadButton}" />
			<Button Command="{Binding EditCommand}" Width="80" Height="30" Margin="0,0,10,0" Content="{x:Static res:Resources.EditButton}" />
			<Button Command="{Binding DeleteCommand}" Width="80" Height="30" Margin="0,0,10,0" Content="{x:Static res:Resources.DeleteButton}" />
			<Button Command="{Binding RefreshCommand}" Width="80" Height="30" Content="Osvezi" />
		</StackPanel>
	</Grid>
</UserControl>