<Window x:Class="RegulationAssistantChatClient.Views.DocumentInfoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:RegulationAssistantChatClient.Properties"
        Title="Document Info"
        Width="450"
        MinWidth="420"
        MinHeight="200"
        SizeToContent="Height"
        Padding="12,12,12,20"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FocusManager.FocusedElement="{Binding ElementName=TitleTextBox}"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource ForegroundBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="Title:" />
        <TextBox x:Name="TitleTextBox" Grid.Row="0" Grid.Column="1" FontSize="14" Padding="6" Margin="0,0,0,12" VerticalContentAlignment="Center"
                 Background="{StaticResource TextBoxBackgroundBrush}" Foreground="{StaticResource TextBoxForegroundBrush}" />

        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="Valid from:" />
        <DatePicker x:Name="ValidFromPicker" Grid.Row="1" Grid.Column="1" Height="30" Width="200" Margin="0,0,0,12"
                    Foreground="{StaticResource TextBoxForegroundBrush}" Background="{StaticResource BackgroundBrush}" CalendarStyle="{StaticResource DarkCalendarStyle}">
            <DatePicker.Resources>
                <Style TargetType="DatePickerTextBox">
                    <Setter Property="Foreground" Value="{StaticResource TextBoxForegroundBrush}" />
                    <Setter Property="Background" Value="{StaticResource TextBoxBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource ForegroundBrush}" />
                </Style>
                <Style TargetType="Button" x:Key="DatePickerButtonStyle">
                    <Setter Property="Background" Value="{StaticResource BackgroundBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource ForegroundBrush}" />
                </Style>
            </DatePicker.Resources>
        </DatePicker>

        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="Valid to:" />
        <DatePicker x:Name="ValidToPicker" Grid.Row="2" Grid.Column="1" Height="30" Width="200" Margin="0,0,0,12"
                    Foreground="{StaticResource TextBoxForegroundBrush}" Background="{StaticResource BackgroundBrush}" CalendarStyle="{StaticResource DarkCalendarStyle}">
            <DatePicker.Resources>
                <Style TargetType="DatePickerTextBox">
                    <Setter Property="Foreground" Value="{StaticResource TextBoxForegroundBrush}" />
                    <Setter Property="Background" Value="{StaticResource TextBoxBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource ForegroundBrush}" />
                </Style>
                <Style TargetType="Button" x:Key="DatePickerButtonStyle">
                    <Setter Property="Background" Value="{StaticResource BackgroundBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource ForegroundBrush}" />
                </Style>
            </DatePicker.Resources>
        </DatePicker>

        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
            <Button x:Name="OkButton" Content="Save" Width="80" Height="30" Margin="0,0,10,0" IsDefault="True" Click="OkButton_Click"
                    Background="{StaticResource ButtonBackgroundBrush}" Foreground="{StaticResource ButtonForegroundBrush}" />
            <Button x:Name="CancelButton" Content="Cancel" Width="80" Height="30" IsCancel="True" Click="CancelButton_Click"
                    Background="{StaticResource ButtonBackgroundBrush}" Foreground="{StaticResource ButtonForegroundBrush}" />
        </StackPanel>
    </Grid>
</Window>